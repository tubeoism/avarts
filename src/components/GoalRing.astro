---
// Donut-style progress ring with the percentage centered inside - shared by the Goals page's
// week/month tiles and its annual per-year table cells (different `size`s, same markup). Visual
// fill clamps at 100% (a full circle), but the centered label always shows the real, uncapped
// percentage so overachieving a goal is still visible as a number.
const { size = 56, strokeWidth = 8, fraction = 0, percent = 0 } = Astro.props;
const r = (size - strokeWidth) / 2;
const c = 2 * Math.PI * r;
const offset = c * (1 - Math.max(0, Math.min(1, fraction)));
const done = percent >= 100;
---
<div class="ring-wrap" style={`--ring-size:${size}px;--ring-font-size:${Math.round(size * 0.22)}px`}>
  <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`}>
    <circle class="ring-track" cx={size / 2} cy={size / 2} r={r} stroke-width={strokeWidth} fill="none" />
    <circle
      class={`ring-fill ${done ? 'done' : ''}`}
      cx={size / 2}
      cy={size / 2}
      r={r}
      stroke-width={strokeWidth}
      fill="none"
      stroke-dasharray={c}
      stroke-dashoffset={offset}
    />
  </svg>
  <div class="ring-pct">{percent.toFixed(1)}%</div>
</div>
