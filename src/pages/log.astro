---
import Layout from '../layouts/Layout.astro';
import T from '../components/T.astro';
---
<Layout titleKey="nav.log">
  <h1><T key="log.title" /></h1>
  <p class="subtitle"><T key="log.subtitle" /></p>

  <div class="log-page">
    <aside class="log-nav">
      <div class="log-nav-current" id="log-nav-current"></div>
      <div class="log-nav-tree" id="log-nav-tree"></div>
    </aside>
    <div class="log-timeline" id="log-timeline">
      <div id="log-loading" class="empty-state"><T key="common.loading" /></div>
    </div>
  </div>
</Layout>

<style is:global>
  /* Most of this page's markup (.log-week/.log-day/.log-bubble/.log-nav-year/...) is created by
     client-side JS rather than the Astro template, so it never gets Astro's scoped-style
     data-astro-cid attribute - this whole block must stay unscoped (is:global) or none of it
     would match. */
  .log-page {
    display: grid;
    grid-template-columns: 190px 1fr;
    gap: 20px;
    align-items: start;
  }

  .log-nav {
    position: sticky;
    top: 76px;
    max-height: calc(100vh - 96px);
    overflow-y: auto;
    padding-right: 4px;
  }

  .log-nav-current {
    font-size: 12px;
    font-weight: 600;
    color: var(--md-primary);
    margin-bottom: 10px;
    min-height: 16px;
  }

  .log-nav-year-btn {
    display: block;
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    padding: 8px 6px;
    font-size: 14px;
    font-weight: 700;
    font-family: inherit;
    color: var(--md-on-surface);
    cursor: pointer;
    border-radius: var(--md-shape-xs);
  }
  .log-nav-year-btn:hover { background: var(--md-surface-container-high); }

  .log-nav-months {
    flex-direction: column;
    padding: 0 0 6px 10px;
  }
  /* [hidden] alone loses to the class selector below at equal specificity (author styles beat
     the UA stylesheet's [hidden] rule) - toggling the `hidden` property from JS would otherwise
     do nothing, so the collapsed state needs its own explicit, higher-specificity rule. */
  .log-nav-months:not([hidden]) {
    display: flex;
  }

  .log-nav-month {
    background: none;
    border: none;
    text-align: left;
    padding: 6px 8px;
    font-size: 13px;
    font-family: inherit;
    color: var(--md-on-surface-variant);
    cursor: pointer;
    border-radius: var(--md-shape-xs);
  }
  .log-nav-month:hover { background: var(--md-surface-container-high); color: var(--md-on-surface); }
  .log-nav-month.active {
    background: var(--md-secondary-container);
    color: var(--md-on-secondary-container);
    font-weight: 600;
  }

  .log-week {
    background: var(--md-surface-container-low);
    border: 1px solid var(--md-outline-variant);
    border-radius: var(--md-shape-lg);
    padding: 16px 18px;
    margin-bottom: 14px;
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .log-week.flash {
    border-color: var(--md-primary);
    box-shadow: 0 0 0 3px var(--md-primary-container);
  }

  .log-week-header {
    font-size: 13px;
    font-weight: 600;
    color: var(--md-on-surface-variant);
    margin-bottom: 12px;
  }

  .log-week-body {
    display: grid;
    grid-template-columns: 1fr 160px;
    gap: 16px;
    align-items: center;
  }

  .log-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
  }

  .log-day {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 4px 2px 6px;
    border-radius: var(--md-shape-sm);
  }
  .log-day.today {
    background: var(--md-primary-container);
  }

  .log-day-label {
    font-size: 10.5px;
    color: var(--md-on-surface-variant);
    text-align: center;
    line-height: 1.3;
    white-space: nowrap;
  }
  .log-day-label .log-day-date { display: block; font-weight: 600; color: var(--md-on-surface); }

  .log-day-bubbles {
    position: relative;
    width: 100%;
    max-width: 82px;
    aspect-ratio: 1;
  }

  .log-bubble {
    position: absolute;
    border-radius: 50%;
    cursor: pointer;
    transition: transform 0.15s ease;
  }
  .log-bubble:hover { transform: scale(1.12); z-index: 5; }

  .log-week-summary {
    display: flex;
    flex-direction: column;
    gap: 8px;
    border-left: 1px solid var(--md-outline-variant);
    padding-left: 16px;
  }

  .log-stat {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    font-size: 13px;
  }
  .log-stat-label { color: var(--md-on-surface-variant); }
  .log-stat-value { font-weight: 600; color: var(--md-on-surface); }

  #log-sentinel { height: 1px; }

  @media (max-width: 760px) {
    .log-page { grid-template-columns: 1fr; }
    .log-nav {
      position: static;
      max-height: none;
      overflow: visible;
      display: flex;
      flex-wrap: wrap;
      align-items: flex-start;
      gap: 6px 14px;
      margin-bottom: 12px;
    }
    .log-nav-current { width: 100%; margin-bottom: 4px; }
    .log-nav-tree { display: flex; flex-wrap: wrap; gap: 6px 14px; width: 100%; }
    .log-nav-year { display: flex; flex-direction: column; }
    .log-nav-months { flex-direction: row; flex-wrap: wrap; padding-left: 0; }
    .log-week-body { grid-template-columns: 1fr; }
    .log-week-summary {
      flex-direction: row;
      justify-content: space-between;
      border-left: none;
      border-top: 1px solid var(--md-outline-variant);
      padding-left: 0;
      padding-top: 10px;
    }
    .log-stat { flex-direction: column; gap: 2px; }
  }

  @media (max-width: 480px) {
    .log-days { gap: 3px; }
    .log-day-bubbles { max-width: 44px; }
    .log-day-label { font-size: 9px; }
  }
</style>

<script>
  import { formatDistance, formatDuration, formatNumber, formatDateTime, activityColor, toVnDate } from '../lib/format.js';
  import { weeklyLogBuckets } from '../lib/stats.mjs';
  import { fetchJsonWithRetry } from '../lib/fetchJson.js';
  import { currentUnitSystem } from '../lib/units.js';
  import { t, activityTypeLabel } from '../lib/i18n.js';
  import { currentLang } from '../lib/lang.js';

  // Bubbles/week-summaries are appended incrementally (infinite scroll), so a unit or language
  // toggle can't just re-run one render() pass over everything visible - instead each element
  // registers itself here at creation time, and the unitschange/langchange listeners below walk
  // the registry to reformat whatever's already on the page in place (no rebuild, keeps scroll
  // position/nav state intact).
  const unitRegistry = { bubbles: [], weekSummaries: [] };

  const MIN_SEC = 180; // 3 min - shorter activities are clamped to the smallest bubble, not shrunk further
  const MAX_SEC = 4 * 3600; // 4h - longer activities are clamped to the largest bubble
  const MIN_FRAC = 0.16; // bubble diameter as a fraction of the (square) day-cell size
  const MAX_FRAC = 0.62;
  const BATCH_SIZE = 10; // weeks appended per infinite-scroll page

  const todayKey = toVnDate(new Date().toISOString()).toISOString().slice(0, 10);

  function bubbleFrac(sec) {
    const t = Math.max(MIN_SEC, Math.min(MAX_SEC, sec || MIN_SEC));
    const f = Math.sqrt((t - MIN_SEC) / (MAX_SEC - MIN_SEC));
    return MIN_FRAC + f * (MAX_FRAC - MIN_FRAC);
  }

  // Places the day's longest activity dead-center and the rest as smaller circles bonded to its
  // rim, evenly spaced by angle (a "molecule" cluster) - then uniformly shrinks the whole cluster
  // if it would overflow the day cell, so a heavy 3-activity day never clips its neighbors.
  function layoutDay(dayActivities) {
    if (!dayActivities.length) return [];
    const sorted = [...dayActivities].sort((a, b) => (b.movingTimeSec || 0) - (a.movingTimeSec || 0));
    const sized = sorted.map((a) => ({ ...a, d: bubbleFrac(a.movingTimeSec) }));
    const [center, ...rest] = sized;
    const nodes = [{ ...center, x: 0, y: 0 }];
    const n = rest.length;
    rest.forEach((s, i) => {
      const angle = -Math.PI / 2 + (i * 2 * Math.PI) / n;
      const dist = center.d / 2 + s.d / 2 - 0.04; // slight overlap so satellites visibly "bond"
      nodes.push({ ...s, x: Math.cos(angle) * dist, y: Math.sin(angle) * dist });
    });
    let maxReach = center.d / 2;
    for (const p of nodes.slice(1)) maxReach = Math.max(maxReach, Math.hypot(p.x, p.y) + p.d / 2);
    const available = 0.48;
    const scale = maxReach > available ? available / maxReach : 1;
    return nodes.map((p) => ({ ...p, d: p.d * scale, x: p.x * scale, y: p.y * scale }));
  }

  function bubbleTitle(node) {
    return `${node.name}\n${activityTypeLabel(currentLang(), node.type)} · ${formatDistance(node.distanceKm, currentUnitSystem())} · ${formatDuration(node.movingTimeSec)}\n${formatDateTime(node.date, node.timezone)}`;
  }

  function bubbleEl(node) {
    const el = document.createElement('div');
    el.className = 'log-bubble';
    const hex = activityColor(node.type);
    el.style.width = `${node.d * 100}%`;
    el.style.height = `${node.d * 100}%`;
    el.style.left = `${(0.5 + node.x - node.d / 2) * 100}%`;
    el.style.top = `${(0.5 + node.y - node.d / 2) * 100}%`;
    el.style.background = hex;
    el.title = bubbleTitle(node);
    el.addEventListener('click', () => { window.location.href = `/activities/${node.id}`; });
    unitRegistry.bubbles.push({ el, node });
    return el;
  }

  function dayEl(day, index) {
    const el = document.createElement('div');
    el.className = 'log-day' + (day.date === todayKey ? ' today' : '');
    const [, m, d] = day.date.split('-');
    const dow = t(currentLang(), 'common.dowShort')[index];
    el.innerHTML = `<div class="log-day-label"><span data-i18n="common.dowShort.${index}">${dow}</span><span class="log-day-date">${d}/${m}</span></div><div class="log-day-bubbles"></div>`;
    const bubbleWrap = el.querySelector('.log-day-bubbles');
    for (const node of layoutDay(day.activities)) bubbleWrap.appendChild(bubbleEl(node));
    return el;
  }

  function weekEl(week) {
    const el = document.createElement('div');
    el.className = 'log-week';
    el.dataset.weekStart = week.weekStart;

    const [sy, sm, sd] = week.weekStart.split('-');
    const [, em, ed] = week.weekEnd.split('-');
    const header = document.createElement('div');
    header.className = 'log-week-header';
    header.textContent = sm === em ? `${sd} – ${ed}/${em}/${sy}` : `${sd}/${sm} – ${ed}/${em}/${sy}`;
    el.appendChild(header);

    const body = document.createElement('div');
    body.className = 'log-week-body';

    const daysWrap = document.createElement('div');
    daysWrap.className = 'log-days';
    week.days.forEach((day, i) => daysWrap.appendChild(dayEl(day, i)));
    body.appendChild(daysWrap);

    const lang = currentLang();
    const summary = document.createElement('div');
    summary.className = 'log-week-summary';
    summary.innerHTML = `
      <div class="log-stat"><span class="log-stat-label" data-i18n="activityDetail.distance">${t(lang, 'activityDetail.distance')}</span><span class="log-stat-value" data-role="week-distance"></span></div>
      <div class="log-stat"><span class="log-stat-label" data-i18n="common.time">${t(lang, 'common.time')}</span><span class="log-stat-value">${formatDuration(week.movingTimeSec)}</span></div>
      <div class="log-stat"><span class="log-stat-label" data-i18n="common.calories">${t(lang, 'common.calories')}</span><span class="log-stat-value">${formatNumber(week.calories)} ${t(lang, 'common.calories')}</span></div>
    `;
    const distEl = summary.querySelector('[data-role="week-distance"]');
    unitRegistry.weekSummaries.push({ distEl, week });
    distEl.textContent = formatDistance(week.km, currentUnitSystem());
    body.appendChild(summary);

    el.appendChild(body);
    return el;
  }

  const timelineEl = document.getElementById('log-timeline');
  const navTreeEl = document.getElementById('log-nav-tree');
  const navCurrentEl = document.getElementById('log-nav-current');

  let weeksDesc = [];
  let renderedCount = 0;
  let currentWeekStart = null;
  const weekElByStart = new Map();

  const sentinel = document.createElement('div');
  sentinel.id = 'log-sentinel';
  const endEl = document.createElement('p');
  endEl.className = 'subtitle';
  endEl.style.cssText = 'text-align:center;display:none';
  endEl.dataset.i18n = 'log.allHistoryShown';
  endEl.textContent = t(currentLang(), 'log.allHistoryShown');

  // Vietnamese always refers to months by number ("Tháng 7"), but English needs an actual month
  // name ("Jul") rather than the literal number - "Month 7" reads as a mistranslation, not a
  // month. log.monthNames (English only) supplies that lookup; monthLabel/viewingLabel templates
  // differ per language to match (see src/i18n/{vi,en}/log.json).
  function monthDisplay(lang, month) {
    return lang === 'en' ? t(lang, 'log.monthNames')[month - 1] : month;
  }

  function updateCurrentLabel() {
    if (!currentWeekStart || !navCurrentEl) return;
    const [y, m] = currentWeekStart.split('-');
    const lang = currentLang();
    navCurrentEl.textContent = t(lang, 'log.viewingLabel', { month: monthDisplay(lang, Number(m)), year: y });
    navTreeEl?.querySelectorAll('.log-nav-month').forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.year === y && btn.dataset.month === String(Number(m)));
    });
  }

  // Thin band near the top of the viewport (below the sticky app bar) - whichever week crosses
  // it becomes "current" for the nav's position label and active-month highlight.
  const spyObserver = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      if (entry.isIntersecting) currentWeekStart = entry.target.dataset.weekStart;
    }
    updateCurrentLabel();
  }, { rootMargin: '-70px 0px -75% 0px', threshold: 0 });

  let sentinelObserver;

  function loadMore() {
    const next = weeksDesc.slice(renderedCount, renderedCount + BATCH_SIZE);
    for (const week of next) {
      const el = weekEl(week);
      timelineEl.insertBefore(el, sentinel);
      weekElByStart.set(week.weekStart, el);
      spyObserver.observe(el);
    }
    renderedCount += next.length;
    if (renderedCount >= weeksDesc.length) {
      sentinelObserver?.disconnect();
      endEl.style.display = 'block';
    }
  }

  function jumpToMonth(year, month) {
    const targetKey = `${year}-${String(month).padStart(2, '0')}`;
    const idx = weeksDesc.findIndex((w) => w.weekStart.slice(0, 7) === targetKey);
    if (idx === -1) return;
    while (renderedCount <= idx && renderedCount < weeksDesc.length) loadMore();
    const target = weekElByStart.get(weeksDesc[idx].weekStart);
    if (!target) return;
    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    target.classList.add('flash');
    setTimeout(() => target.classList.remove('flash'), 1200);
  }

  function buildNavTree(weeksAsc) {
    if (!navTreeEl) return;
    const byYear = new Map();
    for (const w of weeksAsc) {
      const [y, m] = w.weekStart.split('-');
      const year = Number(y);
      if (!byYear.has(year)) byYear.set(year, new Set());
      byYear.get(year).add(Number(m));
    }
    const years = [...byYear.keys()].sort((a, b) => b - a);
    navTreeEl.innerHTML = '';
    years.forEach((year, idx) => {
      const months = [...byYear.get(year)].sort((a, b) => b - a);
      const yearWrap = document.createElement('div');
      yearWrap.className = 'log-nav-year';

      const yearBtn = document.createElement('button');
      yearBtn.type = 'button';
      yearBtn.className = 'log-nav-year-btn';
      yearBtn.textContent = String(year);

      const monthList = document.createElement('div');
      monthList.className = 'log-nav-months';
      monthList.hidden = idx !== 0; // most recent year starts expanded

      yearBtn.addEventListener('click', () => { monthList.hidden = !monthList.hidden; });

      months.forEach((month) => {
        const mBtn = document.createElement('button');
        mBtn.type = 'button';
        mBtn.className = 'log-nav-month';
        mBtn.dataset.year = String(year);
        mBtn.dataset.month = String(month);
        // No data-i18n here (unlike most static text) - the generic repaintLangNodes() pass only
        // does literal {placeholder} substitution and can't compute monthDisplay()'s per-language
        // number-vs-name lookup, so it's handled by the langchange listener below instead, same
        // reasoning as the bubble titles' unitRegistry walk.
        mBtn.textContent = t(currentLang(), 'log.monthLabel', { month: monthDisplay(currentLang(), month) });
        mBtn.addEventListener('click', () => jumpToMonth(year, month));
        monthList.appendChild(mBtn);
      });

      yearWrap.appendChild(yearBtn);
      yearWrap.appendChild(monthList);
      navTreeEl.appendChild(yearWrap);
    });
  }

  fetchJsonWithRetry('/data/activities.json')
    .then((data) => {
      const weeksAsc = weeklyLogBuckets(data);
      weeksDesc = [...weeksAsc].reverse();

      document.getElementById('log-loading')?.remove();
      timelineEl.appendChild(sentinel);
      timelineEl.appendChild(endEl);

      buildNavTree(weeksAsc);
      loadMore();

      sentinelObserver = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) loadMore();
      }, { rootMargin: '800px 0px' });
      sentinelObserver.observe(sentinel);
    })
    .catch((err) => {
      console.error('Failed to load activities.json', err);
      const loadingEl = document.getElementById('log-loading');
      if (loadingEl) {
        const lang = currentLang();
        loadingEl.textContent = t(lang, 'common.loadError');
        const retryBtn = document.createElement('button');
        retryBtn.textContent = t(lang, 'common.retry');
        retryBtn.addEventListener('click', () => location.reload());
        loadingEl.appendChild(retryBtn);
      }
    });

  document.addEventListener('unitschange', () => {
    for (const { el, node } of unitRegistry.bubbles) el.title = bubbleTitle(node);
    for (const { distEl, week } of unitRegistry.weekSummaries) distEl.textContent = formatDistance(week.km, currentUnitSystem());
  });
  // Bubble `title` tooltips mix a translated word (activity type) into a plain string set
  // imperatively, so data-i18n can't reach them (see unitRegistry note above) - re-walk the same
  // registry on langchange. updateCurrentLabel() also depends on language for its "Viewing:"
  // prefix, so it's re-run here too even though its own text isn't in the registry. Nav-tree
  // month buttons are reformatted in place for the same reason as monthDisplay()'s comment -
  // rebuilding the whole tree via buildNavTree() would also reset which year is expanded.
  document.addEventListener('langchange', () => {
    for (const { el, node } of unitRegistry.bubbles) el.title = bubbleTitle(node);
    updateCurrentLabel();
    const lang = currentLang();
    navTreeEl?.querySelectorAll('.log-nav-month').forEach((btn) => {
      const month = Number(btn.dataset.month);
      btn.textContent = t(lang, 'log.monthLabel', { month: monthDisplay(lang, month) });
    });
  });
</script>
